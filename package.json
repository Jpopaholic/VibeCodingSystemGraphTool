{
  "name": "vibegraph",
  "displayName": "VibeGraph",
  "description": "Visual constraint map and prompt compiler for Vibe Coding",
  "version": "0.0.1",
  "publisher": "tttff",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vibegraph.open",
    "onCommand:vibegraph.bootstrap"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibegraph.open",
        "title": "VibeGraph: Open Graph Map",
        "icon": "$(graph)"
      },
      {
        "command": "vibegraph.bootstrap",
        "title": "VibeGraph: Bootstrap Project (產生初始架構)",
        "icon": "$(sparkle)"
      }
    ],
    "keybindings": [
      {
        "command": "vibegraph.bootstrap",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "vibegraph.open" },
        { "command": "vibegraph.bootstrap" }
      ],
      "editor/title": [
        {
          "command": "vibegraph.open",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "vibegraph.bootstrap",
          "group": "navigation",
          "when": "true"
        }
      ],
      "explorer/context": [
        {
          "command": "vibegraph.open",
          "group": "vibegraph@1"
        },
        {
          "command": "vibegraph.bootstrap",
          "group": "vibegraph@2"
        }
      ]
    }
  },
  "scripts": {
    "webview-install": "cd webview && npm install",
    "webview-build": "cd webview && npm run build",
    "package": "npm run webview-build && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0"
  },
  "dependencies": {
    "package": "^1.0.1"
  }
}
